PORT=8080
OPENAI_API_KEY=sk-xxx
# 第三方 OpenAI 兼容接口（如 gptgod），填 base URL 或完整 chat/completions 地址均可
OPENAI_BASE_URL=https://api.gptgod.online/v1
# gptgod 的 API Key 通常有模型白名单，请用 GET /v1/models 查看可用模型
OPENAI_MODEL=gpt-4o-mini

# 可选：配置后会作为降级链中的下一个模型
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
